{
  "openapi": "3.0.0",
  "info": {
    "title": "POS API",
    "description": "API REST para sistema de punto de venta (POS) con gestión de productos, ventas, cajas registradoras, inventario y alertas",
    "version": "1.0.0",
    "contact": {
      "name": "Support"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000/api",
      "description": "Desarrollo"
    },
    {
      "url": "https://api.example.com/api",
      "description": "Producción"
    }
  ],
  "tags": [
    {
      "name": "Autenticación",
      "description": "Endpoints de login y registro"
    },
    {
      "name": "Productos",
      "description": "Operaciones CRUD de productos"
    },
    {
      "name": "Ventas",
      "description": "Gestión de ventas y detalles"
    },
    {
      "name": "Cajas Registradoras",
      "description": "Gestión de cajas registradoras"
    },
    {
      "name": "Inventario",
      "description": "Movimientos y gestión de inventario"
    },
    {
      "name": "Alertas",
      "description": "Gestión de alertas del sistema"
    },
    {
      "name": "Usuarios",
      "description": "Gestión de usuarios"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Token Sanctum Bearer token"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string",
            "enum": ["admin", "cajero"]
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nombre": {
            "type": "string"
          },
          "precio_compra": {
            "type": "number",
            "format": "float"
          },
          "precio_venta": {
            "type": "number",
            "format": "float"
          },
          "stock": {
            "type": "integer"
          },
          "stock_minimo": {
            "type": "integer"
          },
          "codigo_barras": {
            "type": "string",
            "nullable": true
          },
          "imagen": {
            "type": "string",
            "nullable": true
          },
          "activo": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Sale": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "cash_register_id": {
            "type": "string",
            "format": "uuid"
          },
          "metodo_pago": {
            "type": "string",
            "enum": ["efectivo", "yape", "plin"]
          },
          "total": {
            "type": "number",
            "format": "float"
          },
          "cantidad_items": {
            "type": "integer"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "details": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SaleDetail"
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "SaleDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "sale_id": {
            "type": "string",
            "format": "uuid"
          },
          "product_id": {
            "type": "string",
            "format": "uuid"
          },
          "cantidad": {
            "type": "integer"
          },
          "precio_unitario": {
            "type": "number",
            "format": "float"
          },
          "subtotal": {
            "type": "number",
            "format": "float"
          },
          "product": {
            "$ref": "#/components/schemas/Product"
          }
        }
      },
      "CashRegister": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "monto_apertura": {
            "type": "number",
            "format": "float"
          },
          "dinero_contado": {
            "type": "number",
            "format": "float",
            "nullable": true
          },
          "estado": {
            "type": "string",
            "enum": ["abierta", "cerrada"]
          },
          "observacion": {
            "type": "string",
            "nullable": true
          },
          "fecha_apertura": {
            "type": "string",
            "format": "date-time"
          },
          "fecha_cierre": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "InventoryMovement": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "product_id": {
            "type": "string",
            "format": "uuid"
          },
          "tipo": {
            "type": "string",
            "enum": ["entrada", "salida", "ajuste"]
          },
          "cantidad": {
            "type": "integer"
          },
          "motivo": {
            "type": "string"
          },
          "user_id": {
            "type": "string",
            "format": "uuid"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Alert": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "product_id": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "tipo": {
            "type": "string",
            "enum": ["stock_bajo", "agotado", "venta_importante", "otro"]
          },
          "nivel": {
            "type": "string",
            "enum": ["info", "warning", "critical"]
          },
          "titulo": {
            "type": "string"
          },
          "descripcion": {
            "type": "string"
          },
          "leida": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Registrar nuevo usuario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "password_confirmation"],
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 8
                  },
                  "password_confirmation": {
                    "type": "string",
                    "format": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        },
                        "token": {
                          "type": "string"
                        },
                        "token_type": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Validación fallida"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Iniciar sesión",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "user": {
                          "$ref": "#/components/schemas/User"
                        },
                        "token": {
                          "type": "string"
                        },
                        "token_type": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Autenticación"],
        "summary": "Cerrar sesión",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Sesión cerrada"
          }
        }
      }
    },
    "/products": {
      "get": {
        "tags": ["Productos"],
        "summary": "Listar productos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Buscar por nombre o código de barras"
          },
          {
            "name": "activos_only",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Solo productos activos"
          },
          {
            "name": "stock_bajo_only",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Solo con stock bajo"
          },
          {
            "name": "agotados_only",
            "in": "query",
            "schema": {
              "type": "boolean"
            },
            "description": "Solo sin stock"
          },
          {
            "name": "order_by",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Campo para ordenar"
          },
          {
            "name": "order",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["asc", "desc"]
            },
            "description": "Dirección de ordenamiento"
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Resultados por página"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Product"
                      }
                    },
                    "pagination": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Productos"],
        "summary": "Crear producto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["nombre", "precio_compra", "precio_venta", "stock", "stock_minimo"],
                "properties": {
                  "nombre": {
                    "type": "string"
                  },
                  "precio_compra": {
                    "type": "number",
                    "format": "float"
                  },
                  "precio_venta": {
                    "type": "number",
                    "format": "float"
                  },
                  "stock": {
                    "type": "integer"
                  },
                  "stock_minimo": {
                    "type": "integer"
                  },
                  "codigo_barras": {
                    "type": "string"
                  },
                  "imagen": {
                    "type": "string",
                    "format": "binary"
                  },
                  "activo": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Producto creado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Product"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/products/{id}": {
      "get": {
        "tags": ["Productos"],
        "summary": "Obtener producto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Product"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Producto no encontrado"
          }
        }
      },
      "put": {
        "tags": ["Productos"],
        "summary": "Actualizar producto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "nombre": {
                    "type": "string"
                  },
                  "precio_compra": {
                    "type": "number",
                    "format": "float"
                  },
                  "precio_venta": {
                    "type": "number",
                    "format": "float"
                  },
                  "stock": {
                    "type": "integer"
                  },
                  "stock_minimo": {
                    "type": "integer"
                  },
                  "codigo_barras": {
                    "type": "string"
                  },
                  "activo": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Producto actualizado"
          }
        }
      },
      "delete": {
        "tags": ["Productos"],
        "summary": "Eliminar producto",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Producto eliminado"
          }
        }
      }
    },
    "/products/low-stock": {
      "get": {
        "tags": ["Productos"],
        "summary": "Productos con stock bajo",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos con stock bajo"
          }
        }
      }
    },
    "/products/out-of-stock": {
      "get": {
        "tags": ["Productos"],
        "summary": "Productos agotados",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de productos agotados"
          }
        }
      }
    },
    "/products/stats": {
      "get": {
        "tags": ["Productos"],
        "summary": "Estadísticas de productos",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Estadísticas"
          }
        }
      }
    },
    "/sales": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Listar ventas",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "user_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cash_register_id",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "metodo_pago",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["efectivo", "yape", "plin"]
            }
          },
          {
            "name": "hoy",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "este_mes",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "fecha_inicio",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "fecha_fin",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "per_page",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de ventas"
          }
        }
      },
      "post": {
        "tags": ["Ventas"],
        "summary": "Crear venta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["cash_register_id", "metodo_pago", "items"],
                "properties": {
                  "cash_register_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "metodo_pago": {
                    "type": "string",
                    "enum": ["efectivo", "yape", "plin"]
                  },
                  "items": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "product_id": {
                          "type": "string",
                          "format": "uuid"
                        },
                        "cantidad": {
                          "type": "integer"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Venta creada"
          }
        }
      }
    },
    "/sales/{id}": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Obtener detalles de venta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles de venta"
          }
        }
      }
    },
    "/sales/report": {
      "get": {
        "tags": ["Ventas"],
        "summary": "Reporte de ventas",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "fecha_inicio",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "fecha_fin",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Reporte de ventas"
          }
        }
      }
    },
    "/cash-registers": {
      "get": {
        "tags": ["Cajas Registradoras"],
        "summary": "Listar cajas registradoras",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de cajas"
          }
        }
      }
    },
    "/cash-registers/open": {
      "post": {
        "tags": ["Cajas Registradoras"],
        "summary": "Abrir caja",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["monto_apertura"],
                "properties": {
                  "monto_apertura": {
                    "type": "number",
                    "format": "float"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Caja abierta"
          }
        }
      }
    },
    "/cash-registers/my-open-register": {
      "get": {
        "tags": ["Cajas Registradoras"],
        "summary": "Obtener mi caja abierta",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Caja abierta del usuario"
          }
        }
      }
    },
    "/cash-registers/{id}": {
      "get": {
        "tags": ["Cajas Registradoras"],
        "summary": "Obtener caja",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalles de caja"
          }
        }
      }
    },
    "/cash-registers/{id}/close": {
      "post": {
